{
  "serviceName": "AWS PrivateLink",
  "servicePrefix": "vpce",
  "url": "https://docs.aws.amazon.com/service-authorization/latest/reference/./list_awsprivatelink.html",
  "actions": [
    {
      "name": "AllowMultiRegion",
      "documentationUrl": "https://docs.aws.amazon.com/vpc/latest/privatelink/security_iam_service-with-iam.html",
      "description": "Grants permission to manage multi-region VPC endpoints and VPC endpoint service configurations",
      "accessLevel": "Write",
      "resourceTypes": [
        "vpc-endpoint",
        "vpc-endpoint-service"
      ],
      "conditionKeys": [],
      "dependentActions": []
    }
  ],
  "resourceTypes": [
    {
      "name": "vpc-endpoint",
      "arn": "arn:${Partition}:ec2:${Region}:${Account}:vpc-endpoint/${VpcEndpointId}",
      "conditionKeys": []
    },
    {
      "name": "vpc-endpoint-service",
      "arn": "arn:${Partition}:ec2:${Region}:${Account}:vpc-endpoint-service/${VpcEndpointServiceId}",
      "conditionKeys": []
    }
  ]
}